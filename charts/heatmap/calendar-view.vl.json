{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "usermeta": {
    "deneb": {
      "build": "1.9.0.0",
      "metaVersion": 1,
      "provider": "vegaLite",
      "providerVersion": "6.4.1"
    },
    "information": {
      "name": "Calendar View",
      "description": "GitHub-style calendar heatmap showing daily values in a month grid",
      "author": "vegaviz",
      "uuid": "calendar-view-001",
      "generated": "2026-03-16T00:00:00.000Z"
    },
    "dataset": [
      { "key": "__Date__", "name": "Date", "description": "Date field", "type": "dateTime", "kind": "column" },
      { "key": "__Value__", "name": "Value", "description": "Color intensity measure", "type": "numeric", "kind": "measure" }
    ],
    "interactivity": {
      "tooltip": true,
      "contextMenu": true,
      "selection": false,
      "selectionMode": "simple",
      "highlight": false,
      "dataPointLimit": 500
    }
  },
  "data": { "name": "dataset" },
  "width": "container",
  "height": "container",
  "transform": [
    { "calculate": "day(datum['__Date__'])", "as": "dayOfWeek" },
    { "calculate": "date(datum['__Date__'])", "as": "dayOfMonth" },
    { "calculate": "yearmonth(datum['__Date__'])", "as": "month" },
    { "calculate": "ceil((date(datum['__Date__']) + day(datetime(year(datum['__Date__']), month(datum['__Date__']), 1))) / 7)", "as": "weekOfMonth" }
  ],
  "facet": {
    "field": "month",
    "type": "temporal",
    "columns": 4
  },
  "spec": {
    "mark": {
      "type": "rect",
      "cornerRadius": 2,
      "stroke": "#fff",
      "strokeWidth": 2
    },
    "encoding": {
      "x": {
        "field": "weekOfMonth",
        "type": "ordinal",
        "axis": null
      },
      "y": {
        "field": "dayOfWeek",
        "type": "ordinal",
        "axis": {
          "title": null,
          "labelExpr": "['S','M','T','W','T','F','S'][datum.value]"
        }
      },
      "color": {
        "field": "__Value__",
        "type": "quantitative",
        "scale": { "scheme": "pbiColorLinear" },
        "legend": { "title": null }
      },
      "tooltip": [
        { "field": "__Date__", "type": "temporal", "title": "Date", "format": "%b %d, %Y" },
        { "field": "__Value__", "title": "Value", "format": ",.0f" }
      ]
    }
  }
}
