{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "usermeta": {
    "deneb": {
      "build": "1.9.0.0",
      "metaVersion": 1,
      "provider": "vegaLite",
      "providerVersion": "6.4.1"
    },
    "information": {
      "name": "Neath Port Talbot MSOA Hex Map",
      "description": "Hex tile cartogram of Neath Port Talbot's 19 Middle Super Output Areas (MSOAs)",
      "author": "vegaviz",
      "uuid": "npt-msoa-hex-001",
      "generated": "2026-03-16T00:00:00.000Z"
    },
    "dataset": [
      { "key": "__Value__", "name": "Value", "description": "Color intensity measure", "type": "numeric", "kind": "measure" }
    ],
    "interactivity": {
      "tooltip": true,
      "contextMenu": true,
      "selection": true,
      "selectionMode": "simple",
      "highlight": false,
      "dataPointLimit": 50
    }
  },
  "description": "NPT MSOA hex cartogram (19 areas). Coordinates from House of Commons Library. In Deneb, join your data via 'code' (W02000xxx) or 'name'.",
  "data": { "name": "dataset" },
  "width": "container",
  "height": "container",
  "transform": [
    { "calculate": "datum.q * 1.5", "as": "x" },
    { "calculate": "datum.r * 1.732 + (datum.q % 2 === 0 ? 0 : 0.866)", "as": "y" }
  ],
  "layer": [
    {
      "mark": {
        "type": "text",
        "text": "\u2B22",
        "fontSize": 42,
        "baseline": "middle",
        "align": "center"
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative", "axis": null, "scale": { "zero": false } },
        "y": { "field": "y", "type": "quantitative", "axis": null, "sort": "descending", "scale": { "zero": false } },
        "color": {
          "field": "__Value__",
          "type": "quantitative",
          "scale": { "scheme": "pbiColorLinear" },
          "legend": { "title": null }
        },
        "tooltip": [
          { "field": "name", "title": "MSOA" },
          { "field": "code", "title": "Code" },
          { "field": "__Value__", "title": "Value", "format": ",.0f" }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 7,
        "baseline": "middle",
        "align": "center",
        "color": "#ffffff",
        "fontWeight": "bold"
      },
      "encoding": {
        "x": { "field": "x", "type": "quantitative" },
        "y": { "field": "y", "type": "quantitative", "sort": "descending" },
        "text": { "field": "name", "type": "nominal" }
      }
    }
  ]
}
