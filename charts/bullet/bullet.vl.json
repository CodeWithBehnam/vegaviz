          "x": { "field": "__Max__", "type": "quantitative", "axis": { "title": null } }
        }
      },
      {
        "mark": {
          "type": "bar",
          "height": 15,
          "color": { "expr": "pbiColor(0)" }
        },
        "encoding": {
          "x": { "field": "__Actual__", "type": "quantitative" }
