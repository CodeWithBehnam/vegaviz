{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "usermeta": {
    "deneb": {
      "build": "1.9.0.0",
      "metaVersion": 1,
      "provider": "vegaLite",
      "providerVersion": "6.4.1"
    },
    "information": {
      "name": "Cumulative Line Chart",
      "description": "Running total line with year-over-year overlay comparison",
      "author": "vegaviz",
      "uuid": "cumulative-line-001",
      "generated": "2026-03-16T00:00:00.000Z"
    },
    "dataset": [
      { "key": "__Date__", "name": "Date", "description": "Temporal field", "type": "dateTime", "kind": "column" },
      { "key": "__Value__", "name": "Value", "description": "Measure to accumulate", "type": "numeric", "kind": "measure" },
      { "key": "__Year__", "name": "Year", "description": "Year for overlay comparison", "type": "text", "kind": "column" }
    ],
    "interactivity": {
      "tooltip": true,
      "contextMenu": true,
      "selection": false,
      "selectionMode": "simple",
      "highlight": false,
      "dataPointLimit": 50
    }
  },
  "data": { "name": "dataset" },
  "width": "container",
  "height": "container",
  "transform": [
    {
      "sort": [{ "field": "__Date__" }],
      "window": [{ "op": "sum", "field": "__Value__", "as": "cumulative" }],
      "groupby": ["__Year__"]
    },
    { "calculate": "month(datum['__Date__'])", "as": "monthNum" }
  ],
  "mark": {
    "type": "line",
    "strokeWidth": 2
  },
  "encoding": {
    "x": {
      "field": "monthNum",
      "type": "quantitative",
      "axis": { "title": null, "labelExpr": "['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][datum.value]" }
    },
    "y": {
      "field": "cumulative",
      "type": "quantitative",
      "axis": { "title": null }
    },
    "color": {
      "field": "__Year__",
      "type": "nominal",
      "scale": { "scheme": "pbiColorNominal" },
      "legend": { "title": null }
    },
    "tooltip": [
      { "field": "__Year__", "title": "Year" },
      { "field": "cumulative", "title": "Cumulative", "format": ",.0f" }
    ]
  }
}
