{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Project timeline with slicer-driven date grain, measure-controlled range, exact event dates, and start/end markers.https://www.linkedin.com/in/devon-locher/ | https://github.com/DL0K-pbi/PMO_toolkit",
  "data": {
    "name": "dataset"
  },
  "width": "container",
  "height": 180,
  "transform": [
    {
      "calculate": "datum[''Date Grain Mode''] == ''Quarter'' ? datetime(year(datum.Date), floor(month(datum.Date) / 3) * 3, 1) : datetime(year(datum.Date), month(datum.Date), 1)",
      "as": "BucketDate"
    },
    {
      "calculate": "data(''dataset'')[0][''Axis Start Date'']",
      "as": "AxisStart"
    },
    {
      "calculate": "data(''dataset'')[0][''Axis End Date'']",
      "as": "AxisEnd"
    }
  ],
  "encoding": {
    "x": {
      "field": "BucketDate",
      "type": "temporal",
      "title": null,
      "scale": {
        "domain": [
          {
            "expr": "data(''dataset'')[0][''Axis Start Date'']"
          },
          {
            "expr": "data(''dataset'')[0][''Axis End Date'']"
          }
        ],
        "nice": false
      },
      "axis": {
        "tickSize": 0,
        "domain": false,
        "labelFontSize": 11,
        "labelFontWeight": "bold",
        "labelColor": "#003366",
        "labelAlign": "center",
        "labelBaseline": "middle",
        "labelAngle": 0,
        "zindex": 1,
        "tickCount": {
          "expr": "data(''dataset'')[0][''Date Grain Mode''] == ''Quarter'' ? {interval: ''month'', step: 3} : {interval: ''month'', step: 1}"
        },
        "labelExpr": "timeFormat(datum.value, ''%b %Y'')"
      }
    },
    "y": {
      "field": "Height",
      "type": "quantitative",
      "scale": {
        "domain": [
          -1,
          12
        ]
      },
      "axis": null
    }
  },
  "layer": [
    {
      "name": "event-lines",
      "mark": {
        "type": "rule",
        "color": "#FFA500",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "Date"
        },
        "y": {
          "datum": 0
        },
        "y2": {
          "field": "Height"
        }
      }
    },
    {
      "name": "timeline-base",
      "mark": {
        "type": "rule",
        "color": "#003366",
        "strokeWidth": 3
      },
      "encoding": {
        "y": {
          "datum": 0
        },
        "x": {
          "field": "AxisStart"
        },
        "x2": {
          "field": "AxisEnd"
        }
      }
    },
    {
      "name": "timeline-start-ball",
      "mark": {
        "type": "point",
        "filled": true,
        "size": 10,
        "color": "#003366"
      },
      "encoding": {
        "x": {
          "field": "AxisStart"
        },
        "y": {
          "datum": 0
        }
      }
    },
    {
      "name": "timeline-end-arrow",
      "mark": {
        "type": "point",
        "shape": "triangle-right",
        "filled": true,
        "size": 160,
        "color": "#003366",
        "dx": 6
      },
      "encoding": {
        "x": {
          "field": "AxisEnd"
        },
        "y": {
          "datum": 0
        }
      }
    },
    {
      "name": "event-labels",
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "align": "center",
        "color": "#000000",
        "dy": {
          "expr": "datum.Height > 0 ? -8 : 10"
        }
      },
      "encoding": {
        "x": {
          "field": "Date"
        },
        "y": {
          "field": "Height"
        },
        "text": {
          "field": "Name"
        }
      }
    }
  ],
  "config": {
    "view": {
      "stroke": "transparent"
    },
    "axis": {
      "grid": false
    }
  },
  "usermeta": {
    "information": {
      "name": "Project timeline with slicer-driven date grain, measure-cont",
      "source": {
        "repo": "DL0K-pbi/PMO_toolkit",
        "url": "https://github.com/DL0K-pbi/PMO_toolkit"
      }
    }
  }
}